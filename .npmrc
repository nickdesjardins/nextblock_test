# Resilient installs on flaky CI networks (e.g. Vercel's one-click deploy, where the
# full monorepo pulls ~1900 packages). Transient registry drops (ECONNRESET / aborted)
# are retried instead of failing the whole `npm install`. These only affect retry and
# timeout behaviour on network fetches — they do not change resolution, registry, or
# auth, so they are safe for local dev and Docker too.
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
