  "scripts": {
    "build:utils": "node tools/scripts/release-lib.js utils",
    "build:ui": "node tools/scripts/release-lib.js ui",
    "build:db": "node tools/scripts/release-lib.js db",
    "build:editor": "node tools/scripts/release-lib.js editor",
    "build:sdk": "node tools/scripts/release-lib.js sdk",
    "build:ecom": "node tools/scripts/release-lib.js ecommerce",
    "build:cortex": "node tools/scripts/release-lib.js cortex",
    "build:cli": "node tools/scripts/release-cli.js",
    "release:all": "node tools/scripts/release-all.js",
    "all-builds": "nx run-many --target=build --all --exclude nextblock-template,create-nextblock",
    "lib-builds": "nx run-many -t build -p ui -p utils -p db -p editor -p sdk -p cortex",
    "nx:build:nextblock": "nx build nextblock",
    "nx:build:ui": "nx build ui",
    "nx:build:editor": "nx build editor",
    "nx:build:utils": "nx build utils",
    "nx:build:db": "nx build db",
    "nx:build:sdk": "nx build sdk",
    "nx:build:cortex": "nx build cortex",
    "nx:lint:nextblock": "npx nx lint nextblock --skip-nx-cache",
    "nx:lint:create-nextblock": "npx nx lint create-nextblock --skip-nx-cache",
    "nx:lint:ui": "npx nx lint ui --skip-nx-cache",
    "nx:lint:editor": "npx nx lint editor --skip-nx-cache",
    "nx:lint:utils": "npx nx lint utils --skip-nx-cache",
    "nx:lint:db": "npx nx lint db --skip-nx-cache",
    "nx:lint:sdk": "npx nx lint sdk --skip-nx-cache",
    "lint": "npx nx run-many --target=lint --all --exclude nextblock-template --skip-nx-cache",
    "db:backup": "node apps/nextblock/scripts/backup.js",
    "db:restore": "node apps/nextblock/scripts/restore.js",
    "db:types": "node tools/scripts/gen-db-types.js",
    "db:link": "dotenv -e .env.local -- node tools/scripts/supabase-link.js",
    "db:repair": "dotenv -e .env.local -- npx supabase migration repair --status reverted 20260115163000 --workdir libs/db/src",
    "db:reset": "dotenv -e .env.local -- npx supabase db reset --workdir libs/db/src",
    "db:migrate:check": "node tools/scripts/push-db-migrations.js --check",
    "db:migrate": "node tools/scripts/push-db-migrations.js --confirm",
    "db:migrate:fresh": "node tools/scripts/push-db-migrations.js --confirm --allow-baseline-replay",
    "db:migrate:repair-history:check": "node tools/scripts/repair-db-migration-history.js --check",
    "db:migrate:repair-history": "node tools/scripts/repair-db-migration-history.js --confirm",
    "db:push": "node tools/scripts/push-db-migrations.js --confirm",
    "db:push:sandbox": "dotenv -e .env.local -- npx supabase db push --workdir libs/db/src --include-all && dotenv -e .env.local -- npx supabase config push --workdir libs/db/src && dotenv -e .env.local -- npx tsx tools/scripts/seed-sandbox-images.ts && dotenv -e .env.local -- npx supabase functions deploy nextblock-migration-ingest --use-api --workdir libs/db/src",
    "db:functions": "cd libs/db/src && npx dotenv -e ../../../.env.local -- npx supabase functions deploy --use-api",
    "configure:supabase-auth": "dotenv -e .env.local -- node apps/nextblock/tools/configure-supabase-auth.js",
    "sync:create-nextblock": "npm --prefix apps/create-nextblock run sync-template",
    "test-create": "node apps/create-nextblock/bin/create-nextblock.js",
    "deploy:supabase": "node tools/scripts/deploy-supabase.js",
    "generate:sandbox": "npx tsx tools/scripts/generate-sandbox-reset.ts",
    "generate:migrations-bundle": "npx tsx tools/scripts/generate-migrations-bundle.ts",
    "verify:cortex-ai-routing": "npx tsx --tsconfig=tsconfig.base.json apps/nextblock/scripts/verify-cortex-ai-routing.ts",
    "verify:cortex-ai-generate-blocks": "npx tsx --tsconfig=tsconfig.base.json apps/nextblock/scripts/verify-cortex-ai-generate-blocks.ts",
    "verify:cortex-ai-global-tools": "npx tsx --tsconfig=tsconfig.base.json apps/nextblock/scripts/verify-cortex-ai-global-tools.ts",
    "verify:cortex-ai-build-widget": "npx tsx --tsconfig tsconfig.base.json apps/nextblock/scripts/verify-cortex-ai-build-widget.tsx",
    "verify:editor-block-schema": "npx tsx apps/nextblock/scripts/validate-editor-block-schema.ts",
    "sandbox:reset": "node tools/scripts/reset-sandbox.js",
    "stripe": "stripe listen --forward-to localhost:4200/api/webhooks/stripe",
    "setup": "node tools/scripts/setup.mjs",
    "docker:setup": "node tools/scripts/docker-setup.mjs",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f nextblock-cms"
  },
