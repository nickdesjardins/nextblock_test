{
  "name": "@nextblock-cms/cortex",
  "version": "0.12.6",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextblock-cms/packages.git"
  },
  "type": "module",
  "main": "./index.cjs.js",
