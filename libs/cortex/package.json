      "scope:premium"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.42",
    "@nextblock-cms/db": "workspace:*",
    "@nextblock-cms/ecommerce": "workspace:*",
    "@nextblock-cms/utils": "workspace:*",
    "ai": "^6.0.170",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "next": "^16.2.7"
  }
}
